  node:
  - Name: NPC5
    Dialog: "\uC5B4? \uB9C8\uCE68 \uC798 \uC654\uC5B4. \uD639\uC2DC \uBD80\uD0C1
      \uD558\uB098\uB9CC \uD574\uB3C4 \uB420\uAE4C?"
  - Name: NPC5
    Dialog: "\uC6B0\uB9AC \uD560\uC544\uBC84\uC9C0\uAC00 \uC5B4\uB9B4 \uB54C \uB4DC\uC2DC\uB358
      \uACFC\uC77C\uC774 \uADF8\uB9AC\uC6B0\uC2DC\uB2E4\uB294\uB370,"
  - Name: NPC5
    Dialog: " \uD639\uC2DC \uAC00\uC838\uC640 \uC904 \uC218 \uC788\uC744\uAE4C?"
  - Name: NPC5
    Dialog: "\uC790\uC138\uD55C \uC704\uCE58\uB294 \uD560\uC544\uBC84\uC9C0\uD55C\uD14C
      \uBB3C\uC5B4\uBD10."
  - Name: NPC5
    Dialog: "\uD560\uC544\uBC84\uC9C0\uB294 \uC232 \uC18D\uC5D0 \uACC4\uC2E4\uAC70\uC57C"
